function applyFilters(){
  var q=document.getElementById('searchBox').value.toLowerCase().trim();
  var filtered=STAFF.filter(function(s){
    if(F.desig.size>0&&!F.desig.has(s.position)) return false;
    if(F.section.size>0&&!F.section.has(s.section)) return false;
    if(F.cat.size>0){
      var ok=false;
      var codes=(s.approCat||'').split(',').map(function(x){return x.trim();}).filter(function(x){return x;});
      var hasCode=function(arr){return arr.every(function(x){return codes.indexOf(x)!==-1;});};
      var isB1=hasCode(['A','B']); var isB1Full=isB1&&codes.indexOf('C')!==-1; var isB1Ltd=isB1&&codes.indexOf('C')===-1;
      var isB2Full=hasCode(['C','G','K']);
      var isB2Ltd=!isB1&&((codes.indexOf('C')!==-1&&codes.indexOf('G')===-1&&codes.indexOf('K')===-1)||(codes.indexOf('C')!==-1&&codes.indexOf('G')!==-1&&codes.indexOf('K')===-1)||(codes.indexOf('G')!==-1&&codes.indexOf('K')!==-1&&codes.indexOf('C')===-1));
      var isCatA=codes.indexOf('M')!==-1;
      if(F.cat.has('B1 Full')&&isB1Full) ok=true; if(F.cat.has('B1 Ltd')&&isB1Ltd) ok=true;
      if(F.cat.has('B2 Full')&&isB2Full) ok=true; if(F.cat.has('B2 Ltd')&&isB2Ltd) ok=true;
      if(F.cat.has('Cat A')&&isCatA) ok=true; if(!ok) return false;
    }
    if(F.auth.size>0){ var ok=false; F.auth.forEach(function(a){ if(s.authApprovals&&s.authApprovals[a]&&s.authApprovals[a].length>0) ok=true; }); if(!ok) return false; }
    if(q&&(s.name+' '+s.approNo).toLowerCase().indexOf(q)===-1) return false;
    return true;
  });
  filtered.sort(function(a,b){ return a.name.localeCompare(b.name); });
  renderTable(filtered);
  updateCountBar(filtered);
  document.getElementById('resultInfo').textContent=filtered.length+' of '+STAFF.length+' staff';
}

