      <div class="filter-group" id="fCatGrp"><div class="fgl">Approval Category</div><div class="filter-pills" id="fCat"></div></div>
    </div>
    <div class="filter-row">
      <div class="filter-group"><div class="fgl">Search</div><input type="text" class="search-box" id="searchBox" placeholder="Name / approval no..." oninput="applyFilters()"></div>
      <button class="btn-clear" onclick="clearAll()">Clear All</button>
      <div class="result-info" id="resultInfo"></div>
    </div>
  </div>
  <div id="countBar" style="display:none;background:#fff;border-radius:12px;border:1px solid #f0f2f8;padding:10px 16px;margin-bottom:10px;overflow-x:auto;"></div>
  <div class="table-card"><div class="table-wrap"><table id="tbl"><thead id="tHead"></thead><tbody id="tBody"></tbody></table></div></div>
</div>
<script>
var DQ = String.fromCharCode(34);
function h(s){ return s.replace(/[|]/g, DQ); }

