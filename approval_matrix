var CODE_COLORS = {
  A:'#6366f1', B:'#3b82f6', C:'#10b981',
  G:'#f59e0b', K:'#f97316', M:'#ec4899', T:'#8b5cf6'
};

// ─── CHANGE 3: Engine type shortener ──────────────────────────────────────
// Applied to authority cell text before rendering
function shortenEngineType(text){
  if(!text) return text;
  return text
    .replace(/\(CFM56[-\w]*\)/g,      '(CFM56)')
    .replace(/\(CFM LEAP[-\w]*\)/gi,  '(Leap)')
    .replace(/\(IAE PW\d+\w*\)/gi,    '(PW110)')
    .replace(/\(IAE V2500\)/gi,        '(V2500)')
    .replace(/\(RRT[-\w.]*\)/gi,       '(Trent)')
    .replace(/\(GE CF6[-\w]*\)/gi,     '(CF6)');
}

function nav(page){
  try{
    google.script.run.withSuccessHandler(function(u){
      window.top.location.href = page === 'landing' ? u : u + '?page=' + page;
    }).getScriptUrl();
  } catch(ex){ window.location.href = '?page=' + page; }
}
function showLoader(msg){ var el=document.getElementById('loaderOverlay'); el.classList.remove('hide'); document.getElementById('loaderMsg').textContent=msg||'Loading approval matrix...'; }
function hideLoader(){ document.getElementById('loaderOverlay').classList.add('hide'); }

window.addEventListener('DOMContentLoaded', function(){
  showLoader('Loading approval matrix data...');
  document.addEventListener('change', function(e){
    var inp=e.target;
    if(inp.tagName==='INPUT'&&inp.type==='checkbox'&&inp.closest('.fpill')){
      var key=inp.getAttribute('data-key'), val=inp.value;
      if(!key) return;
      if(inp.checked){ F[key].add(val); inp.closest('.fpill').classList.add('active'); }
      else { F[key].delete(val); inp.closest('.fpill').classList.remove('active'); }
      applyFilters();
    }
  });
  google.script.run
    .withSuccessHandler(function(result){
      var raw=result.staff||[];
      STAFF=raw.filter(function(s){ return /^ADE/i.test((s.approNo||'').trim()); });
      hideLoader();
      buildKpis();
      buildFilters();
      switchTab('typeRating');
      var sn=document.getElementById('sheetName');
      if(sn) sn.textContent=result.sheetName?'Sheet: '+result.sheetName:'';
    })
    .withFailureHandler(function(e){
      hideLoader();
      var ed=document.createElement('div');
      ed.style.cssText='display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:12px';
      var eh=document.createElement('h2'); eh.textContent='Access Denied'; eh.style.color='#dc2626';
      var ep=document.createElement('p'); ep.textContent=e.message||String(e); ep.style.color='#6b7280';
      document.body.innerHTML=''; document.body.appendChild(ed); ed.appendChild(eh); ed.appendChild(ep);
    })
    .getApprovalMatrixData();
});

function buildKpis(){
  var s=STAFF;
  function parseCodes(val){ if(!val) return []; return val.split(',').map(function(c){return c.trim();}).filter(function(c){return c;}); }
  function hasAll(codes,arr){ return arr.every(function(x){return codes.indexOf(x)!==-1;}); }
  var b1FullOnly=0,b1LtdOnly=0,b2FullOnly=0,b2LtdOnly=0,b1b2=0,catAOnly=0,ab2=0;
  s.forEach(function(st){
    var codes=parseCodes(st.approCat);
    var hasB1=hasAll(codes,['A','B']); var hasB1Full=hasB1&&codes.indexOf('C')!==-1; var hasB1Ltd=hasB1&&codes.indexOf('C')===-1;
    var hasB2Full=hasAll(codes,['C','G','K']);
    var hasB2Ltd=!hasB1&&((codes.indexOf('C')!==-1&&codes.indexOf('G')===-1&&codes.indexOf('K')===-1)||(codes.indexOf('C')!==-1&&codes.indexOf('G')!==-1&&codes.indexOf('K')===-1)||(codes.indexOf('G')!==-1&&codes.indexOf('K')!==-1&&codes.indexOf('C')===-1));
    var hasB2=hasB2Full||hasB2Ltd; var hasA=codes.indexOf('M')!==-1;
