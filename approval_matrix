              var b=document.createElement('span');
              b.style.cssText='display:inline-flex;padding:1px 5px;border-radius:4px;font-size:9px;font-weight:700;margin:1px;background:'
                +(lic==='B1'?'#eef2ff':lic==='B2'?'#f5f3ff':'#ecfdf5')
                +';color:'+(lic==='B1'?'#4f46e5':lic==='B2'?'#7c3aed':'#059669');
              b.textContent=lic; td.appendChild(b);
            });
          } else { var dot=document.createElement('div'); dot.className='dot-n'; td.appendChild(dot); }
        } else {
          var letters=(s.typeMatrix&&s.typeMatrix[col.id])?s.typeMatrix[col.id]:[];
          if(letters.length>0){
            letters.forEach(function(ltr){
              if(ltr==='T') return;
              var b=document.createElement('span');
              var bgc=CODE_COLORS[ltr]||'#9ca3af';
              b.style.cssText='display:inline-flex;padding:1px 4px;border-radius:3px;font-size:9px;font-weight:800;margin:1px;color:#fff;background:'+bgc;
              b.textContent=ltr; td.appendChild(b);
            });
          } else { var dot=document.createElement('div'); dot.className='dot-n'; td.appendChild(dot); }
        }

      } else if(ACTIVE_TAB==='approval'){
        td.className='dot-cell';
        td.style.cssText='text-align:center;width:'+dw+';min-width:'+dw+';max-width:'+dw+';padding:2px';
        var has=!!s.canonicals[col.id];
        var dot=document.createElement('div'); dot.className=has?'dot-y':'dot-n';
        if(has) dot.style.background='#6366f1';
        td.appendChild(dot);

      } else {
        // Authority tab — CHANGE 3: apply shortenEngineType() on cell text
        var authApprovals=s.authApprovals&&s.authApprovals[col.id];
        if(authApprovals&&authApprovals.length>0){
          td.style.cssText='vertical-align:top;text-align:center;padding:4px 6px;min-width:100px;width:100px;max-width:140px;background:#fff;border-right:1px solid #f0f2f8';
          authApprovals.forEach(function(appr){
            var dv=document.createElement('div');
            dv.style.cssText='font-size:9px;color:#1f2937;line-height:1.5;white-space:nowrap;overflow:hidden;text-overflow:ellipsis';
            var short=shortenEngineType(appr);
            dv.textContent=short; dv.title=appr; // full text on hover
            td.appendChild(dv);
          });
        } else {
          td.style.cssText='text-align:center;min-width:100px;width:100px;max-width:140px;padding:0;vertical-align:middle';
          var dot=document.createElement('div'); dot.className='dot-n'; dot.style.margin='auto'; td.appendChild(dot);
        }
      }
      tr.appendChild(td);
    });
    frag.appendChild(tr);
  });
  body.innerHTML=''; body.appendChild(frag);
}

function clearAll(){
  F.desig.clear(); F.section.clear(); F.auth.clear(); F.cat.clear();
  document.getElementById('searchBox').value='';
  document.querySelectorAll('.fpill.active').forEach(function(el){
    el.classList.remove('active'); el.querySelector('input').checked=false;
  });
  applyFilters();
}
</script>
