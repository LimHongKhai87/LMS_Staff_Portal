      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>Type Rating
    </button>
    <!-- CHANGE 1: "Foreign Authority" → "Authority" -->
    <button class="tab-btn" id="tabAuthority" onclick="switchTab('authority')">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>Authority
    </button>
  </div>
  <div class="sec-hdr" style="margin-top:16px"><span class="sec-lbl">Filters</span><div class="sec-line"></div></div>
  <div class="filter-card">
    <div class="filter-row">
      <div class="filter-group"><div class="fgl">Designation</div><div class="filter-pills" id="fDesig"></div></div>
      <div class="fdivider"></div>
      <div class="filter-group"><div class="fgl">Section</div><div class="filter-pills" id="fSection"></div></div>
