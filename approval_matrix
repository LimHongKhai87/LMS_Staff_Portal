<title>Matrix | ADE KUL</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f6fa;color:#1a1d23;font-size:13px;-webkit-font-smoothing:antialiased}@keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
.loading-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;background:#fff;position:fixed;inset:0;z-index:200}
.loading-screen.hide{display:none}
.spinner{border:4px solid #e5e7eb;border-top:4px solid #6b7280;border-radius:50%;width:50px;height:50px;animation:spin .8s linear infinite}
.loading-screen p{margin-top:16px;color:#6b7280;font-weight:500;font-size:14px}

.topbar{background:#fff;border-bottom:1px solid #eef2f7;padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:56px;position:sticky;top:0;z-index:200;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.tb-left{display:flex;align-items:center;gap:12px}
.tb-badge{background:#eef2ff;border-radius:8px;padding:4px 10px;font-size:11px;font-weight:700;color:#6366f1;letter-spacing:.4px}
.tb-title{font-size:15px;font-weight:700;color:#1a1d23}
.tb-sub{font-size:11px;color:#8a92a6;margin-top:1px}
.tb-right{display:flex;align-items:center;gap:8px}
.nav-btn{padding:6px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;border:1.5px solid #e5e9f0;background:#fff;color:#6b7280;font-family:inherit;transition:all .15s;white-space:nowrap}
.nav-btn:hover{border-color:#6366f1;color:#6366f1;background:#f5f3ff}
.content{padding:20px 28px 48px;overflow:visible}@media(max-width:768px){.content{padding:12px 0 40px}.table-card,.filter-card{border-radius:0;border-left:none;border-right:none}.tab-row{padding:0 12px}.sec-hdr{padding:0 12px}.kpi-strip{padding:0 12px}}
.sec-hdr{display:flex;align-items:center;gap:12px;margin:24px 0 14px}
.sec-hdr:first-child{margin-top:0}
.sec-lbl{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#b0b7c3;white-space:nowrap}
.sec-line{flex:1;height:1px;background:#eef2f7}
.kpi-strip{display:flex;gap:12px;flex-wrap:wrap}
.kpi-tile{background:#fff;border-radius:14px;padding:16px 18px;flex:1;min-width:100px;box-shadow:0 2px 10px rgba(0,0,0,.05);border:1px solid #f0f2f8}
.kpi-icon-ring{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:8px}
.kpi-icon-ring svg{width:17px;height:17px}
.kpi-num{font-size:24px;font-weight:800;line-height:1;letter-spacing:-1.5px;margin-bottom:3px}
.kpi-lbl{font-size:11px;color:#8a92a6;font-weight:500}
.tab-row{display:flex;gap:8px}
.tab-btn{padding:9px 22px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;border:2px solid #e5e9f0;background:#fff;color:#8a92a6;font-family:inherit;transition:all .18s;display:flex;align-items:center;gap:8px}
.tab-btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.tab-btn:hover{border-color:#6366f1;color:#4f46e5;background:#f5f3ff}
.tab-btn.active{background:#6366f1;color:#fff;border-color:#6366f1;box-shadow:0 4px 12px rgba(99,102,241,.3)}
.filter-card{background:#fff;border-radius:14px;padding:16px 20px;box-shadow:0 2px 10px rgba(0,0,0,.05);border:1px solid #f0f2f8;margin-bottom:16px}
.filter-row{display:flex;align-items:flex-start;gap:20px;flex-wrap:wrap;margin-bottom:10px}
.filter-row:last-child{margin-bottom:0}
.filter-group{display:flex;flex-direction:column;gap:5px}
.fgl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#8a92a6}
.filter-pills{display:flex;flex-wrap:wrap;gap:5px}
.fpill{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;border:1.5px solid #e5e9f0;background:#fff;font-size:11px;font-weight:600;color:#6b7280;cursor:pointer;transition:all .15s;user-select:none}
.fpill:hover{border-color:#a5b4fc;color:#4f46e5}
.fpill.active{background:#eef2ff;border-color:#6366f1;color:#4f46e5}
.fpill input{display:none}
.fdivider{width:1px;background:#eef2f7;align-self:stretch;margin:2px 0}
.search-box{padding:6px 12px;border:1.5px solid #e5e9f0;border-radius:8px;font-size:12px;font-family:inherit;color:#1a1d23;width:400px;background:#f8f9fd;transition:border-color .15s}
.search-box:focus{outline:none;border-color:#6366f1;background:#fff}
.btn-clear{padding:6px 14px;border-radius:8px;font-size:11px;font-weight:600;cursor:pointer;border:1.5px solid #e5e9f0;background:#fff;color:#8a92a6;font-family:inherit;transition:all .15s;align-self:flex-end}
.btn-clear:hover{border-color:#ef4444;color:#ef4444}
.result-info{font-size:11px;color:#8a92a6;align-self:center;white-space:nowrap}
.table-card{background:#fff;border-radius:14px;box-shadow:0 2px 10px rgba(0,0,0,.05);border:1px solid #f0f2f8;overflow:hidden}
.table-wrap{overflow-x:auto;overflow-y:auto;-webkit-overflow-scrolling:touch;max-height:calc(100vh - 360px)}
table{border-collapse:separate;border-spacing:0;font-size:11px;min-width:max-content;width:100%}
thead th{background:#f8f9fd;border-bottom:1px solid #eef2f7;position:sticky;z-index:50;padding:0 10px;height:34px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#8a92a6;white-space:nowrap;text-align:left;border-right:1px solid #f0f2f8}
thead tr.grp-row th{height:28px;font-size:9px;font-weight:700;color:#fff;text-align:center;border-right:1px solid rgba(255,255,255,.15);top:0}
thead tr.field-row th{top:28px}
.rot-th{writing-mode:vertical-rl;transform:rotate(180deg);height:110px;padding:8px 4px;vertical-align:bottom;font-size:9px;max-width:30px;min-width:30px;text-align:left;white-space:normal;word-break:break-word}

/* ─── Sticky identity column widths ─────────────────────────────────────── */
.sc-name{position:sticky;left:0;z-index:40;background:#fff;width:270px;min-width:270px;max-width:270px;font-weight:600;overflow:hidden;text-overflow:ellipsis}
.sc-appr{background:#fff;min-width:85px;max-width:85px;font-size:10px;color:#8a92a6}
.sc-sec{background:#fff;min-width:50px;max-width:50px;border-right:2px solid #e5e9f0 !important}
.sc-sno{background:#fff;min-width:75px;max-width:75px;font-size:10px;color:#8a92a6}
thead th.sc-sno{z-index:61;background:#f8f9fd}
thead th.sc-name,thead th.sc-appr,thead th.sc-sec{z-index:61;background:#f8f9fd}

tbody td{padding:8px 10px;border-bottom:1px solid #f5f6fa;border-right:1px solid #f5f6fa;vertical-align:middle;background:#fff;white-space:nowrap}
tbody tr:hover td{background:#f8f9fd}
tbody tr:hover td.sc-name,tbody tr:hover td.sc-appr,tbody tr:hover td.sc-sec{background:#eef2ff}
td.dot-cell{text-align:center;width:56px;min-width:56px;max-width:56px;padding:2px}
.dot-y{display:inline-flex;width:18px;height:18px;border-radius:50%;align-items:center;justify-content:center}
.dot-y::after{content:"";width:6px;height:6px;border-radius:50%;background:#fff}
.dot-n{display:inline-flex;width:18px;height:18px;border-radius:50%;background:#f0f2f8}

.cat-badge{display:inline-flex;padding:2px 6px;border-radius:6px;font-size:10px;font-weight:700;white-space:nowrap;margin-right:2px}
.cb-b1{background:#eef2ff;color:#4f46e5}.cb-b2{background:#f5f3ff;color:#7c3aed}
.cb-c{background:#ecfdf5;color:#065f46}.cb-a1{background:#fffbeb;color:#92400e}
.sec-nb{display:inline-flex;padding:2px 7px;border-radius:6px;font-size:10px;font-weight:700;background:#fbbf24;color:#fff}
.sec-wb{display:inline-flex;padding:2px 7px;border-radius:6px;font-size:10px;font-weight:700;background:#2563eb;color:#fff}
.no-data{padding:60px;text-align:center;color:#8a92a6;font-size:13px}
</style>
