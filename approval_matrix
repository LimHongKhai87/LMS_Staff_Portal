};
function nameW(){ return ACTIVE_TAB === 'typeRating' ? COL_W.nameTR : COL_W.name; }
var STICKY_LEFT = {
  name:    0,
  staffNo: COL_W.name,
  apprNo:  COL_W.name + COL_W.staffNo,
  sec:     COL_W.name + COL_W.staffNo + COL_W.apprNo
};

var STAFF = [];
var CANONICALS = [
  {id:'cgk_a320_cfm56_maa',  label:'CGK A320-200 (CFM56-5B) CAAM - MAA'},
  {id:'cgk_a320_cfm56_iaa',  label:'CGK A320-200 (CFM56-5B) DGCA - IAA'},
  {id:'cgk_a320_cfm56_paa',  label:'CGK A320-200 (CFM56-5B) CAAP - PAA'},
  {id:'cgk_a320_cfm56_aac',  label:'CGK A320-200 (CFM56-5B) SSCA - AAC'},
  {id:'cgk_a320_leap_maa',   label:'CGK A320-200 (CFM LEAP-1A) CAAM - MAA'},
  {id:'cgk_a320_v2500',      label:'CGK A320-200 (IAE V2500)'},
  {id:'cgk_a321_cfm56_maa',  label:'CGK A321-200 (CFM56-5B) CAAM - MAA'},
  {id:'cgk_a321_leap_maa',   label:'CGK A321-200NX (CFM LEAP-1A) CAAM - MAA'},
  {id:'cgk_a330_rrt_maa',    label:'CGK A330-343 (RRT772B-60) CAAM - MAA'},
  {id:'cgk_a330_rrt_aax',    label:'CGK A330-343 (RRT772B-60) CAAM - AAX'},
  {id:'ab_a330_rrt_aax',     label:'AB A330-343 (RRT772B-60) CAAM - AAX'},
  {id:'cgk_b737_cfm56',      label:'CGK B737-600/700/800/900 (CFM56)'},
];
var ACTIVE_TAB = 'typeRating';
var F = { desig: new Set(), section: new Set(), auth: new Set(), cat: new Set() };

var TR_GROUPS = [
  {id:'a320', label:'A320', bg:'#1e3a5f', engines:[
    {id:'A320_CFM56',   eng:'CFM56',   label:'A320 CFM56'},
    {id:'A320_LEAP-1A', eng:'LEAP-1A', label:'A320 LEAP-1A'},
    {id:'A320_PW1100',  eng:'PW1100',  label:'A320 PW1100G'},
    {id:'A320_V2500',   eng:'V2500',   label:'A320 V2500'},
  ]},
  {id:'a321', label:'A321', bg:'#1e4a6f', engines:[
    {id:'A321_CFM56',   eng:'CFM56',   label:'A321 CFM56'},
    {id:'A321_LEAP-1A', eng:'LEAP-1A', label:'A321 LEAP-1A'},
    {id:'A321_PW1100',  eng:'PW1100',  label:'A321 PW1100G'},
    {id:'A321_V2500',   eng:'V2500',   label:'A321 V2500'},
  ]},
  {id:'a330', label:'A330', bg:'#14532d', engines:[
    {id:'A330_RRT772B-60', eng:'RRT772B-60', label:'A330 RRT772B'},
    {id:'A330_GE CF6',     eng:'GE CF6',     label:'A330 GE CF6'},
  ]},
  {id:'b737', label:'B737', bg:'#4c1d2a', engines:[
    {id:'B737_classic', eng:'classic', label:'Classic', isB737:true, dataKey:'b737'},
    {id:'B737_ng',      eng:'ng',      label:'NG',      isB737:true, dataKey:'b737'},
    {id:'B737_max',     eng:'max',     label:'MAX',     isB737:true, dataKey:'b737'},
  ]},
  {id:'a350', label:'A350', bg:'#6b21a8', engines:[
    {id:'A350_TRXWB', eng:'TRXWB', label:'A350 Trent XWB', isB737:true, dataKey:'a350'},
  ]},
];
// AUTH_GROUPS aligned to QN-G-017 Rev 02 (05 Dec 2025)
var AUTH_GROUPS = [
  // Table 1 — Malaysia
  {label:'CAAM',         nation:'Malaysia',    bg:'#1e3a5f', cols:[{id:'MAA',        label:'MAA'},{id:'AAX',       label:'AAX'}]},
  // Table 2 — Indonesia  (TNU = TransNusa per QN-G-017)
  {label:'DGCA Indonesia',nation:'Indonesia',  bg:'#4c1d2a', cols:[{id:'IAA',        label:'IAA'},{id:'TNU',       label:'TNU'}]},
  // Table 3 — Philippines  (PAA only per QN-G-017; PAL & Cebu removed)
  {label:'CAAP',         nation:'Philippines', bg:'#312e81', cols:[{id:'PAA',        label:'PAA'}]},
  // Table 4 — Singapore
  {label:'CAAS',         nation:'Singapore',   bg:'#1c2526', cols:[{id:'Scoot',      label:'Scoot'}]},
  // Table 5 — Thailand
  {label:'CAAT',         nation:'Thailand',    bg:'#14532d', cols:[{id:'TAA',        label:'TAA'}]},
  // Table 6 — Nepal
  {label:'CAAN',         nation:'Nepal',       bg:'#27272a', cols:[{id:'HIM',        label:'HIM'}]},
  // Table 7 — Myanmar  (MAI = Myanmar Airways Intl per QN-G-017)
  {label:'DCAM',         nation:'Myanmar',     bg:'#102020', cols:[{id:'MAI',        label:'MAI'}]},
  // Table 8 — India  (IGO = Indigo per QN-G-017)
  {label:'DGCA India',   nation:'India',       bg:'#2a1a2e', cols:[{id:'IGO',        label:'IGO'}]},
  // Table 9 — Cambodia  (KME = Cambodia Airways per QN-G-017)
  {label:'SSCA',         nation:'Cambodia',    bg:'#1a2030', cols:[{id:'AAC',        label:'AAC'},{id:'KME',       label:'KME'}]},
  // Table 10 — Bermuda
  {label:'BCAA',         nation:'Bermuda',     bg:'#1a3020', cols:[{id:'HKJ',        label:'HKJ'}]},
  // Table 11 — Bhutan  (DRK = Druk Air; authority = BCAA Bhutan per QN-G-017)
  {label:'BCAA Bhutan',  nation:'Bhutan',      bg:'#1c2318', cols:[{id:'DRK',        label:'DRK'}]},
  // Table 12 — EASA  (AFI = Air France per QN-G-017)
  {label:'EASA',         nation:'Europe',      bg:'#10102a', cols:[{id:'AFI',        label:'AFI'}]},
  // Table 14 — Vietnam  (SPA = Sun PhuQuoc Airways per QN-G-017)
  {label:'CAAV',         nation:'Vietnam',     bg:'#1a3a3a', cols:[{id:'SPA',        label:'SPA'}]},
  // Table 15 — Guernsey
  {label:'ODCA',         nation:'Guernsey',    bg:'#2a1520', cols:[{id:'Castlelake', label:'Castlelake'}]},
  // Table 16 — Pakistan (Reserved — authority column retained for future use, no operator cols)
  {label:'PCAA',         nation:'Pakistan',    bg:'#2a2010', cols:[]},
