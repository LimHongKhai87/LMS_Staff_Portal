// ─── CHANGE 4: mkFixedTh now supports top offset for sticky-left cells ────
function mkFixedTh(label, w, opts){
  var th = document.createElement('th');
  th.textContent = label;
  var bg     = opts.bg     || '#1f2937';
  var color  = opts.color  || '#fff';
  var height = opts.height || 34;
  var base  = 'color:'+color+';font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;'
             +'height:'+height+'px;text-align:center;white-space:nowrap;border-right:1px solid rgba(255,255,255,.15);'
             +'width:'+w+'px;min-width:'+w+'px;max-width:'+w+'px;padding:0 4px;background:'+bg+';';
  if(opts.sticky){
    // Sticky-left: honour both left AND top so it locks in the correct row
    base += 'position:sticky;left:'+(opts.left||0)+'px;top:'+(opts.top||0)+'px;z-index:71;';
  } else {
    base += 'position:sticky;top:'+(opts.top||0)+'px;z-index:50;';
  }
  th.style.cssText = base;
  if(opts.className) th.className = opts.className;
  if(opts.rowspan)   th.setAttribute('rowspan', String(opts.rowspan));
  return th;
}

