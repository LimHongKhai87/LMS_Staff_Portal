      icPart2.addEventListener('input', function() { this.value = this.value.replace(/\D/g, '').slice(0, 2); if (this.value.length === 2) icPart3.focus(); updateIcNo(); });
      icPart3.addEventListener('input', function() { this.value = this.value.replace(/\D/g, '').slice(0, 4); updateIcNo(); });
