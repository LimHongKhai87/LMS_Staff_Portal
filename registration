    function calculateAge() {
      var dob = new Date(document.getElementById('date_of_birth').value);
      var today = new Date();
      var age = today.getFullYear() - dob.getFullYear();
      var m = today.getMonth() - dob.getMonth();
      if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) age--;
      document.getElementById('age').value = age >= 0 ? age : '';
    }
    
    function calculateYearsInAviation() {
      var yearJoined = parseInt(document.getElementById('year_aviation').value);
      if (!yearJoined) { document.getElementById('total_years_aviation').value = ''; return; }
      var currentYear = new Date().getFullYear();
      var total = currentYear - yearJoined;
      document.getElementById('total_years_aviation').value = total >= 0 ? total : '';
    }
    
    function calculateEmploymentYears(suffix) {
      var start = new Date(document.getElementById('start_date_' + suffix).value);
      var end = new Date(document.getElementById('end_date_' + suffix).value);
      if (start && end && end > start) {
        document.getElementById('year_' + suffix).value = ((end - start) / (1000 * 60 * 60 * 24 * 365.25)).toFixed(1);
      }
    }
    
    function updateYearEstablishAndCalculateSigning() {
      var month = document.getElementById('year_establish_month').value;
      var year = document.getElementById('year_establish_year').value;
      document.getElementById('year_establish').value = (month && year) ? year + '-' + month : '';
    }
    
    // ── Navigation & Validation ────────────────────────────────────────────
    function navigate(direction) {
      var newStep = currentStep + direction;
      if (direction > 0 && !validateCurrentSection()) return;
      if (newStep < 1 || newStep > totalSteps) {
        if (newStep > totalSteps) showConfirmationDialog();
        return;
      }
      currentStep = newStep;
      updateSections();
      updateProgress();
      updateNavigation();
      window.scrollTo({ top: 0, behavior: 'smooth' });
      hideAlert();
    }
    
    function validateCurrentSection() {
      var isValid = true;
      var firstInvalid = null;
      
      if (currentStep === 1) {
        ['full_name','staff_no','joining_date','date_of_birth','nationality','gender','designation','main_trade','year_aviation'].forEach(function(id) {
          var field = document.getElementById(id);
          if (!field.value.trim()) { isValid = false; field.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = field; }
          else field.style.borderColor = '#d1d5db';
        });
        var phone = document.getElementById('phone_number');
        if (!phone.value.trim()) { isValid = false; phone.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = phone; }
        else phone.style.borderColor = '#d1d5db';
        var nationality = document.getElementById('nationality').value;
        var isMalaysia = nationality.toLowerCase() === 'malaysia' || nationality.toLowerCase() === 'malaysia';
        if (isMalaysia) {
          [['ic_part1',6],['ic_part2',2],['ic_part3',4]].forEach(function(spec) {
            var el = document.getElementById(spec[0]);
            if (el.value.length !== spec[1]) { isValid = false; el.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = el; }
            else el.style.borderColor = '#d1d5db';
          });
          var icPic = document.getElementById('ic_picture');
          if (!icPic.files || !icPic.files[0]) { isValid = false; icPic.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = icPic; }
          else icPic.style.borderColor = '#d1d5db';
        }
      }
      
      if (currentStep === 2) {
        var count = parseInt(document.getElementById('no_of_employment').value) || 0;
        ['last','second_last','third_last'].slice(0, count).forEach(function(suffix) {
          var company = document.getElementById('company_' + suffix);
          if (!company.value.trim()) { isValid = false; company.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = company; }
          else company.style.borderColor = '#d1d5db';
          ['start_date_' + suffix, 'end_date_' + suffix].forEach(function(id) {
            var field = document.getElementById(id);
            if (!field.value) { isValid = false; field.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = field; }
            else field.style.borderColor = '#d1d5db';
          });
          ['section_' + suffix, 'designation_' + suffix, 'type_' + suffix].forEach(function(key) {
            var trigger = document.querySelector('#ms_' + key + ' .ms-trigger');
            if (!msState[key] || msState[key].length === 0) { isValid = false; if (trigger) trigger.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = trigger; }
            else if (trigger) trigger.style.borderColor = '#d1d5db';
          });
        });
      }
      
      if (currentStep === 3) {
        var licenseSelected = msState['available_license'] || [];
        if (licenseSelected.length === 0) { showAlert('Please select at least one license option', 'error'); return false; }
        var hasAMEL = licenseSelected.includes('CAAM AMEL (B/C)');
        var hasAMTL = licenseSelected.includes('CAAM AMTL (A)');
        var hasLicense = hasAMEL || hasAMTL;
        if (hasAMEL) {
          var t = document.querySelector('#ms_amel_category .ms-trigger');
          if (!msState['amel_category'] || msState['amel_category'].length === 0) { isValid = false; if (t) t.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = t; }
          else if (t) t.style.borderColor = '#d1d5db';
          var amelLic = document.getElementById('amel_license');
          if (!amelLic.value.trim()) { isValid = false; amelLic.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = amelLic; }
          else amelLic.style.borderColor = '#d1d5db';
          ['amel_issue_date','amel_license_expiry'].forEach(function(id) {
            var f = document.getElementById(id);
            if (!f.value) { isValid = false; f.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = f; }
            else f.style.borderColor = '#d1d5db';
          });
          var amelCats = msState['amel_category'] || [];
          if ((amelCats.includes('B1.1')||amelCats.includes('B1.1 Limited')) && (!msState['b1_type_rating']||msState['b1_type_rating'].length===0)) { isValid = false; var t2 = document.querySelector('#ms_b1_type_rating .ms-trigger'); if (t2) t2.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = t2; }
          if ((amelCats.includes('B2')||amelCats.includes('B2 Limited')) && (!msState['b2_type_rating']||msState['b2_type_rating'].length===0)) { isValid = false; var t3 = document.querySelector('#ms_b2_type_rating .ms-trigger'); if (t3) t3.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = t3; }
          if (amelCats.includes('Cat C') && (!msState['c_type_rating']||msState['c_type_rating'].length===0)) { isValid = false; var t4 = document.querySelector('#ms_c_type_rating .ms-trigger'); if (t4) t4.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = t4; }
          var amelPic = document.getElementById('amel_picture');
          if (!amelPic.files || !amelPic.files[0]) { isValid = false; amelPic.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = amelPic; }
          else amelPic.style.borderColor = '#d1d5db';
        }
        if (hasAMTL) {
          var amtlCat = document.getElementById('amtl_license_category');
          if (!amtlCat.value) { isValid = false; amtlCat.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = amtlCat; }
          else amtlCat.style.borderColor = '#d1d5db';
          var amtlNo = document.getElementById('amtl_license_no');
          if (!amtlNo.value.trim()) { isValid = false; amtlNo.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = amtlNo; }
          else amtlNo.style.borderColor = '#d1d5db';
          ['amtl_issue_date','amtl_license_expiry'].forEach(function(id) {
            var f = document.getElementById(id);
            if (!f.value) { isValid = false; f.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = f; }
            else f.style.borderColor = '#d1d5db';
          });
          if (amtlCat.value === 'A1' && (!msState['a1_type_rating']||msState['a1_type_rating'].length===0)) { isValid = false; var t5 = document.querySelector('#ms_a1_type_rating .ms-trigger'); if (t5) t5.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = t5; }
          var amtlPic = document.getElementById('amtl_picture');
          if (!amtlPic.files || !amtlPic.files[0]) { isValid = false; amtlPic.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = amtlPic; }
          else amtlPic.style.borderColor = '#d1d5db';
        }
        if (hasLicense) {
          var ym = document.getElementById('year_establish_month');
          var yy = document.getElementById('year_establish_year');
          if (!ym.value) { isValid = false; ym.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = ym; } else ym.style.borderColor = '#d1d5db';
          if (!yy.value) { isValid = false; yy.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = yy; } else yy.style.borderColor = '#d1d5db';
        }
      }
      
      if (currentStep === 4) {
        ['address','state','next_of_kin_name','relationship'].forEach(function(id) {
          var field = document.getElementById(id);
          if (!field.value.trim()) { isValid = false; field.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = field; }
          else field.style.borderColor = '#d1d5db';
        });
        var kinPhone = document.getElementById('kin_phone_number');
        if (!kinPhone.value.trim()) { isValid = false; kinPhone.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = kinPhone; }
        else kinPhone.style.borderColor = '#d1d5db';
        if (document.getElementById('passport_available').value === 'Available') {
          ['passport_no','passport_expiry'].forEach(function(id) {
            var f = document.getElementById(id);
            if (!f.value.trim()) { isValid = false; f.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = f; }
            else f.style.borderColor = '#d1d5db';
          });
          var passportPic = document.getElementById('passport_picture');
          if (!passportPic.files || !passportPic.files[0]) { isValid = false; passportPic.style.borderColor = '#dc2626'; if (!firstInvalid) firstInvalid = passportPic; }
          else passportPic.style.borderColor = '#d1d5db';
        }
      }
      
      if (!isValid) {
        showAlert('Please fill in all required fields', 'error');
        if (firstInvalid && firstInvalid.focus) firstInvalid.focus();
      }
      return isValid;
    }
    
    function updateSections() {
      document.querySelectorAll('.section').forEach(function(s) { s.classList.remove('active'); });
      document.querySelector('.section[data-section="' + currentStep + '"]').classList.add('active');
    }
    
    function updateProgress() {
      document.querySelectorAll('.progress-step').forEach(function(step, index) {
        var num = index + 1;
        step.classList.remove('active', 'completed');
        if (num < currentStep) step.classList.add('completed');
        else if (num === currentStep) step.classList.add('active');
      });
      document.querySelectorAll('.progress-line').forEach(function(line, index) {
        line.classList.toggle('completed', index < currentStep - 1);
      });
    }
    
    function updateNavigation() {
      var prevBtn = document.getElementById('prevBtn');
      var nextBtn = document.getElementById('nextBtn');
      prevBtn.style.display = currentStep === 1 ? 'none' : 'flex';
      if (currentStep === totalSteps) { nextBtn.textContent = 'Submit'; nextBtn.classList.remove('btn-primary'); nextBtn.classList.add('btn-success'); }
      else { nextBtn.innerHTML = 'Next →'; nextBtn.classList.remove('btn-success'); nextBtn.classList.add('btn-primary'); }
    }
    
    // ── Form submission ────────────────────────────────────────────────────
    function collectFormData() {
      var form = document.getElementById('registrationForm');
      var formData = {};
      form.querySelectorAll('input, select, textarea').forEach(function(input) {
        if (input.type === 'file') return;
        if (input.closest('.ms-dropdown')) return;
        if (input.id && input.id.startsWith('ic_part')) return;
        if (input.name) formData[input.name] = input.value;
      });
      formData.phone_no = '+60' + document.getElementById('phone_number').value;
      formData.next_of_kin_contact_no = '+60' + document.getElementById('kin_phone_number').value;
      formData.email_address = document.getElementById('email_address').value;
      formData.age = document.getElementById('age').value;
      formData.ic_no = document.getElementById('ic_no').value;
      ['type_last','type_second_last','type_third_last','section_last','section_second_last','section_third_last',
       'designation_last','designation_second_last','designation_third_last',
       'available_license','amel_category','b1_type_rating','b2_type_rating','c_type_rating','a1_type_rating'].forEach(function(key) {
        formData[key] = document.getElementById(key + '_values').value;
      });
      formData.year_last = document.getElementById('year_last').value;
      formData.year_second_last = document.getElementById('year_second_last').value;
      formData.year_third_last = document.getElementById('year_third_last').value;
      return formData;
    }
    
    function getPictureBase64(inputId) {
      return new Promise(function(resolve) {
        var input = document.getElementById(inputId);
        if (input.files && input.files[0]) {
          var reader = new FileReader();
          reader.onload = function(e) { resolve(e.target.result); };
          reader.readAsDataURL(input.files[0]);
        } else {
          resolve('');
        }
      });
    }
    
    function handleSuccess(result) {
      document.getElementById('loadingOverlay').classList.remove('show');
      if (result.success) {
        document.getElementById('registrationForm').style.display = 'none';
        document.querySelector('.progress-container').style.display = 'none';
        document.querySelector('.form-header').style.display = 'none';
        document.getElementById('successScreen').classList.add('show');
        document.getElementById('navButtons').style.display = 'none';
      } else {
        document.getElementById('navButtons').style.display = 'flex';
        showAlert(result.message, 'error');
      }
    }
    
    function handleError(error) {
      document.getElementById('loadingOverlay').classList.remove('show');
      document.getElementById('navButtons').style.display = 'flex';
      showAlert('Error: ' + (error.message || error), 'error');
    }
    
    function showAlert(message, type) {
      var alertBox = document.getElementById('alertBox');
      alertBox.textContent = message;
      alertBox.className = 'alert alert-' + type;
      alertBox.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    
    function hideAlert() { document.getElementById('alertBox').style.display = 'none'; }

    // ── Confirmation dialog ────────────────────────────────────────────────
    async function showConfirmationDialog() {
      if (!validateCurrentSection()) return;
      var formData = collectFormData();
      formData.ic_picture_base64      = await getPictureBase64('ic_picture');
      formData.amel_picture_base64    = await getPictureBase64('amel_picture');
      formData.amtl_picture_base64    = await getPictureBase64('amtl_picture');
      formData.passport_picture_base64 = await getPictureBase64('passport_picture');
      
      var html = '<div class="confirmation-dialog-overlay" id="confirmationOverlay">';
      html += '<div class="confirmation-dialog">';
      html += '<div class="confirmation-header"><h2>Confirm Your Registration</h2><p>Please review your information before submitting:</p></div>';
      html += '<div class="confirmation-body">';
      html += '<div class="confirm-section"><h3>Personal Information</h3>';
      html += '<div class="confirm-row"><label>Full Name:</label><span>' + (formData.full_name || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>Email:</label><span>' + (formData.email_address || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>Staff No:</label><span>' + (formData.staff_no || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>IC No:</label><span>' + (formData.ic_no || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>Date of Birth:</label><span>' + (formData.date_of_birth || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>Nationality:</label><span>' + (formData.nationality || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>Gender:</label><span>' + (formData.gender || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>Phone:</label><span>' + (formData.phone_no || '-') + '</span></div>';
      html += '<div class="confirm-row"><label>Designation:</label><span>' + (formData.designation || '-') + '</span></div>';
      html += '</div>';
      var empCount = parseInt(formData.no_of_employment) || 0;
      if (empCount > 0) {
        html += '<div class="confirm-section"><h3>Employment History (' + empCount + ' previous employment' + (empCount > 1 ? 's' : '') + ')</h3>';
        [['last','Most Recent'],['second_last','2nd'],['third_last','3rd']].slice(0, empCount).forEach(function(pair) {
          var s = pair[0], label = pair[1];
          if (formData['company_' + s]) {
            html += '<div class="confirm-employment"><strong>' + label + ' Employment:</strong><br>Company: ' + (formData['company_' + s] || '-') + '<br>Section: ' + (formData['section_' + s] || '-') + '<br>Period: ' + (formData['start_date_' + s] || '-') + ' to ' + (formData['end_date_' + s] || '-') + '</div>';
          }
        });
        html += '</div>';
      }
      if (formData.available_license && formData.available_license !== 'None') {
        html += '<div class="confirm-section"><h3>CAAM License</h3>';
        html += '<div class="confirm-row"><label>License Type:</label><span>' + (formData.available_license || '-') + '</span></div>';
        if (formData.available_license.indexOf('AMEL') !== -1) {
          html += '<div class="confirm-row"><label>AMEL Category:</label><span>' + (formData.amel_category || '-') + '</span></div>';
          html += '<div class="confirm-row"><label>AMEL No:</label><span>' + (formData.amel_license || '-') + '</span></div>';
          html += '<div class="confirm-row"><label>AMEL Expiry:</label><span>' + (formData.amel_license_expiry || '-') + '</span></div>';
        }
        if (formData.available_license.indexOf('AMTL') !== -1) {
          html += '<div class="confirm-row"><label>AMTL No:</label><span>' + (formData.amtl_license_no || '-') + '</span></div>';
          html += '<div class="confirm-row"><label>AMTL Expiry:</label><span>' + (formData.amtl_license_expiry || '-') + '</span></div>';
        }
        html += '</div>';
      }
      html += '<div class="confirm-section"><h3>Documents Uploaded</h3>';
      var docs = [];
      if (formData.ic_picture_base64) docs.push('IC');
      if (formData.amel_picture_base64) docs.push('AMEL License');
      if (formData.amtl_picture_base64) docs.push('AMTL License');
      if (formData.passport_picture_base64) docs.push('Passport');
      html += '<div class="confirm-row"><label>Files:</label><span>' + (docs.length > 0 ? docs.join(', ') : 'None') + '</span></div>';
      html += '</div>';
      html += '</div>';
      html += '<div class="confirmation-footer">';
      html += '<button type="button" class="btn-confirm-cancel" onclick="closeConfirmation()">Cancel</button>';
      html += '<button type="button" class="btn btn-primary" onclick="confirmSubmission()">Confirm &amp; Submit</button>';
      html += '</div></div></div>';
      
      document.body.insertAdjacentHTML('beforeend', html);
      window._pendingFormData = formData;
    }

    function closeConfirmation() {
      var overlay = document.getElementById('confirmationOverlay');
      if (overlay) overlay.remove();
      window._pendingFormData = null;
    }

    function confirmSubmission() {
      var formData = window._pendingFormData;
      if (!formData) { showAlert('Error: Form data not found', 'error'); return; }
      closeConfirmation();
      document.getElementById('loadingOverlay').classList.add('show');
      document.getElementById('navButtons').style.display = 'none';
      google.script.run
        .withSuccessHandler(handleSuccess)
        .withFailureHandler(handleError)
        .submitForm(formData);
    }
    
    function checkAndDismissAlert() {
      var alertBox = document.getElementById('alertBox');
      if (alertBox.style.display === 'none') return;
      var allValid = true;
      if (currentStep === 1) {
        ['full_name','staff_no','joining_date','date_of_birth','nationality','gender','designation','main_trade','year_aviation'].forEach(function(id) { if (!document.getElementById(id).value.trim()) allValid = false; });
        if (!document.getElementById('phone_number').value.trim()) allValid = false;
        var nat = document.getElementById('nationality').value;
        var isMY = nat.toLowerCase() === 'malaysia' || nat.toLowerCase() === 'malaysia';
        if (isMY) {
          if (document.getElementById('ic_part1').value.length !== 6) allValid = false;
          if (document.getElementById('ic_part2').value.length !== 2) allValid = false;
          if (document.getElementById('ic_part3').value.length !== 4) allValid = false;
          var icPicEl = document.getElementById('ic_picture');
          if (!icPicEl.files || !icPicEl.files[0]) allValid = false;
        }
      }
      if (currentStep === 2) {
        var count = parseInt(document.getElementById('no_of_employment').value) || 0;
        ['last','second_last','third_last'].slice(0, count).forEach(function(s) {
          if (!document.getElementById('company_' + s).value.trim()) allValid = false;
          if (!document.getElementById('start_date_' + s).value) allValid = false;
          if (!document.getElementById('end_date_' + s).value) allValid = false;
          ['section_' + s,'designation_' + s,'type_' + s].forEach(function(key) { if (!msState[key]||msState[key].length===0) allValid = false; });
        });
      }
      if (currentStep === 3) {
        var lic = msState['available_license'] || [];
        if (lic.length === 0) { allValid = false; }
        var hasAMEL = lic.includes('CAAM AMEL (B/C)');
        var hasAMTL = lic.includes('CAAM AMTL (A)');
        if (hasAMEL) {
          if (!msState['amel_category']||msState['amel_category'].length===0) allValid = false;
          if (!document.getElementById('amel_license').value.trim()) allValid = false;
          if (!document.getElementById('amel_issue_date').value) allValid = false;
          if (!document.getElementById('amel_license_expiry').value) allValid = false;
          var amelPicEl = document.getElementById('amel_picture'); if (!amelPicEl.files||!amelPicEl.files[0]) allValid = false;
          var cats = msState['amel_category']||[];
          if ((cats.includes('B1.1')||cats.includes('B1.1 Limited'))&&(!msState['b1_type_rating']||msState['b1_type_rating'].length===0)) allValid=false;
          if ((cats.includes('B2')||cats.includes('B2 Limited'))&&(!msState['b2_type_rating']||msState['b2_type_rating'].length===0)) allValid=false;
          if (cats.includes('Cat C')&&(!msState['c_type_rating']||msState['c_type_rating'].length===0)) allValid=false;
        }
        if (hasAMTL) {
          if (!document.getElementById('amtl_license_category').value) allValid = false;
          if (!document.getElementById('amtl_license_no').value.trim()) allValid = false;
          if (!document.getElementById('amtl_issue_date').value) allValid = false;
          if (!document.getElementById('amtl_license_expiry').value) allValid = false;
          var amtlPicEl = document.getElementById('amtl_picture'); if (!amtlPicEl.files||!amtlPicEl.files[0]) allValid = false;
          if (document.getElementById('amtl_license_category').value==='A1'&&(!msState['a1_type_rating']||msState['a1_type_rating'].length===0)) allValid=false;
        }
        if (hasAMEL||hasAMTL) {
          if (!document.getElementById('year_establish_month').value) allValid=false;
          if (!document.getElementById('year_establish_year').value) allValid=false;
        }
      }
      if (currentStep === 4) {
        ['address','state','next_of_kin_name','relationship'].forEach(function(id) { if (!document.getElementById(id).value.trim()) allValid=false; });
        if (!document.getElementById('kin_phone_number').value.trim()) allValid=false;
        if (document.getElementById('passport_available').value==='Available') {
          if (!document.getElementById('passport_no').value.trim()) allValid=false;
          if (!document.getElementById('passport_expiry').value) allValid=false;
          var passportPicEl=document.getElementById('passport_picture'); if (!passportPicEl.files||!passportPicEl.files[0]) allValid=false;
        }
      }
      if (allValid) hideAlert();
    }
    
    // ── Expose to global scope ─────────────────────────────────────────────
    window.navigate = navigate;
    window.goToProfile = goToProfile;
    window.toggleMsPanel = toggleMsPanel;
    window.toggleMsOption = toggleMsOption;
    window.closeMsPanel = closeMsPanel;
    window.removeMsValue = removeMsValue;
    window.showConfirmationDialog = showConfirmationDialog;
    window.closeConfirmation = closeConfirmation;
    window.confirmSubmission = confirmSubmission;
    
  })();
  </script>
</body>
</html>
