    // ── Helpers ────────────────────────────────────────────────────────────
    function setupIcInputs() {
      var icPart1 = document.getElementById('ic_part1');
      var icPart2 = document.getElementById('ic_part2');
      var icPart3 = document.getElementById('ic_part3');
