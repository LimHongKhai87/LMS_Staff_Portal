    // ── Multi-select component ─────────────────────────────────────────────
    function initMultiSelect(key, options, placeholder, config) {
      config = config || {};
      msState[key] = [];
      msOptions[key] = options;
      var container = document.getElementById('ms_' + key);
      if (!container) return;
      container.dataset.msKey = key;
      container.dataset.placeholder = placeholder;
      if (config.noneOption) container.dataset.noneOption = config.noneOption;
      if (config.exclusions) container._exclusions = config.exclusions;
      if (config.onChangeCallback) container._onChangeCallback = config.onChangeCallback;
      renderMultiSelect(key);
    }
    
    function renderMultiSelect(key) {
      var container = document.getElementById('ms_' + key);
      if (!container) return;
      var placeholder = container.dataset.placeholder || '+ Add';
      var options = msOptions[key] || [];
      var selected = msState[key] || [];
      var noneOption = container.dataset.noneOption || null;
      var exclusions = container._exclusions || {};
      var disabledSet = {};
      selected.forEach(function(val) {
        disabledSet[val] = true;
        if (exclusions[val]) exclusions[val].forEach(function(ex) { disabledSet[ex] = true; });
      });
      if (noneOption && selected.includes(noneOption)) {
        options.forEach(function(opt) { if (opt !== noneOption) disabledSet[opt] = true; });
      }
      if (noneOption && selected.length > 0 && !selected.includes(noneOption)) {
        disabledSet[noneOption] = true;
      }
      var html = '<div class="ms-trigger" onclick="toggleMsPanel(\'' + key + '\')">';
      html += '<span>' + placeholder + '</span><span class="ms-arrow">▼</span></div>';
      html += '<div class="ms-panel" id="ms_panel_' + key + '">';
      options.forEach(function(opt) {
        var isSelected = selected.includes(opt);
        var isDisabled = disabledSet[opt] && !isSelected;
        var cls = 'ms-option' + (isSelected ? ' selected' : '') + (isDisabled ? ' disabled' : '');
        html += '<div class="' + cls + '" data-value="' + opt + '" onclick="toggleMsOption(\'' + key + '\', \'' + opt.replace(/'/g, "\\'") + '\')">';
        html += '<input type="checkbox" ' + (isSelected ? 'checked' : '') + ' ' + (isDisabled ? 'disabled' : '') + ' tabindex="-1">';
        html += '<label>' + opt + '</label></div>';
      });
      html += '<button type="button" class="ms-done-btn" onclick="closeMsPanel(\'' + key + '\')">Done</button></div>';
      container.innerHTML = html;
    }
    
    function toggleMsPanel(key) {
      var panel = document.getElementById('ms_panel_' + key);
      var container = document.getElementById('ms_' + key);
      var trigger = container.querySelector('.ms-trigger');
      var isOpen = panel.classList.contains('open');
      closeAllMsPanels(key);
      if (!isOpen) { panel.classList.add('open'); trigger.classList.add('open'); }
    }
    
    function closeMsPanel(key) {
      var panel = document.getElementById('ms_panel_' + key);
      var container = document.getElementById('ms_' + key);
      if (panel) panel.classList.remove('open');
      var trigger = container ? container.querySelector('.ms-trigger') : null;
      if (trigger) trigger.classList.remove('open');
    }
    
    function closeAllMsPanels(exceptKey) {
      Object.keys(msState).forEach(function(key) { if (key !== exceptKey) closeMsPanel(key); });
    }
    
    function toggleMsOption(key, value) {
      var container = document.getElementById('ms_' + key);
      var noneOption = container ? container.dataset.noneOption : null;
      var selected = msState[key] || [];
      var idx = selected.indexOf(value);
      if (idx > -1) {
        selected.splice(idx, 1);
      } else {
        if (noneOption && value === noneOption) { msState[key] = [value]; }
        else if (noneOption && selected.includes(noneOption)) { msState[key] = [value]; }
        else { selected.push(value); }
      }
      renderMultiSelect(key);
      var panel = document.getElementById('ms_panel_' + key);
      var trigger = document.getElementById('ms_' + key).querySelector('.ms-trigger');
      if (panel) panel.classList.add('open');
      if (trigger) trigger.classList.add('open');
      updateMsBadges(key);
      updateMsHiddenInput(key);
      if (container._onChangeCallback) container._onChangeCallback(msState[key]);
    }
    
    function updateMsBadges(key) {
      var badgesContainer = document.getElementById('badges_' + key);
      var countContainer = document.getElementById('count_' + key);
      var selected = msState[key] || [];
      var trigger = document.querySelector('#ms_' + key + ' .ms-trigger');
      if (trigger && selected.length > 0) trigger.style.borderColor = '#d1d5db';
      checkAndDismissAlert();
      if (badgesContainer) {
        badgesContainer.innerHTML = '';
        selected.forEach(function(val) {
          var badge = document.createElement('span');
          badge.className = 'badge';
          badge.innerHTML = val + ' <button type="button" class="badge-remove" onclick="removeMsValue(\'' + key + '\', \'' + val.replace(/'/g, "\\'") + '\')">&times;</button>';
          badgesContainer.appendChild(badge);
        });
      }
      if (countContainer) {
        if (selected.length > 0) { countContainer.textContent = selected.length + ' selected'; countContainer.style.display = 'inline'; }
        else { countContainer.textContent = ''; countContainer.style.display = 'none'; }
      }
    }
    
    function updateMsHiddenInput(key) {
      var input = document.getElementById(key + '_values');
      if (input) input.value = (msState[key] || []).join(', ');
    }
    
    function removeMsValue(key, value) {
      msState[key] = (msState[key] || []).filter(function(v) { return v !== value; });
      renderMultiSelect(key);
      updateMsBadges(key);
      updateMsHiddenInput(key);
      var container = document.getElementById('ms_' + key);
      if (container && container._onChangeCallback) container._onChangeCallback(msState[key]);
    }
    
    function clearMsValues(key) {
      msState[key] = [];
      renderMultiSelect(key);
      updateMsBadges(key);
      updateMsHiddenInput(key);
    }
    
