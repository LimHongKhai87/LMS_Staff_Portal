<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5; color: #333; font-size: 13px;
      -webkit-font-smoothing: antialiased;
    }
    .loading-screen {
      display: flex; flex-direction: column; align-items: center;
      justify-content: center; height: 100vh; background: #fff;
    }
    .spinner {
      border: 4px solid #e5e7eb; border-top: 4px solid #6b7280;
      border-radius: 50%; width: 44px; height: 44px;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }
    .loading-screen p { margin-top: 14px; color: #6b7280; font-weight: 500; font-size: 15px; }

    .page { display: none; flex-direction: column; height: 100vh; overflow: hidden; }
    .page.show { display: flex; }

    .topbar {
      background: #fff; border-bottom: 1px solid #e5e7eb;
      padding: 12px 24px; display: flex; align-items: center;
      justify-content: space-between; gap: 16px; flex-shrink: 0;
    }
    .topbar-title    { font-size: 16px; font-weight: 700; color: #1f2937; letter-spacing: -0.3px; }
    .topbar-subtitle { font-size: 12px; color: #9ca3af; }

    .stats-row {
      background: #fff; border-bottom: 1px solid #e5e7eb;
      padding: 8px 24px; display: flex; gap: 24px; flex-wrap: wrap;
      flex-shrink: 0; align-items: center;
    }
    .stat-item  { display: flex; flex-direction: column; }
    .stat-value { font-size: 18px; font-weight: 700; color: #1f2937; line-height: 1.2; }
    .stat-label { font-size: 11px; color: #9ca3af; font-weight: 500; text-transform: uppercase; letter-spacing: 0.3px; }
    .stat-divider { width: 1px; background: #e5e7eb; align-self: stretch; margin: 2px 0; }

    .filter-bar {
      background: #fff; border-bottom: 1px solid #e5e7eb;
      padding: 8px 24px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      flex-shrink: 0;
    }
    .filter-label { font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.4px; white-space: nowrap; }
    .filter-select {
      padding: 5px 8px; border: 1.5px solid #e5e7eb; border-radius: 6px;
      font-size: 12px; color: #374151; background: #f9fafb; cursor: pointer;
      transition: border-color 0.15s;
    }
    .filter-select:focus { outline: none; border-color: #6b7280; }
    .search-input {
      padding: 5px 8px; border: 1.5px solid #e5e7eb; border-radius: 6px;
      font-size: 12px; color: #374151; background: #f9fafb; min-width: 380px;
      transition: border-color 0.15s;
    }
    .search-input:focus { outline: none; border-color: #6b7280; }
    .btn-clear {
      padding: 5px 12px; border: 1.5px solid #d1d5db; border-radius: 6px;
      font-size: 12px; font-weight: 500; color: #6b7280; background: #fff;
      cursor: pointer; transition: all 0.15s; font-family: inherit;
    }
    .btn-clear:hover { background: #f3f4f6; color: #374151; }
    .result-count { font-size: 12px; color: #9ca3af; margin-left: auto; white-space: nowrap; }

    .table-wrap { flex: 1; overflow: auto; -webkit-overflow-scrolling: touch; }

    table { border-collapse: separate; border-spacing: 0; font-size: 12px; min-width: max-content; }

    thead tr.group-row th {
      background: #1f2937; color: #fff;
      font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px;
      padding: 0 12px; height: 34px; text-align: center; white-space: nowrap;
      border-right: 1px solid #374151;
      position: sticky; top: 0; z-index: 50;
    }
    thead tr.group-row th.sg1 { position: sticky; left: 0;     top: 0; z-index: 90; text-align: left; background: #1f2937; }
    thead tr.group-row th.sg2 { position: sticky; left: 315px; top: 0; z-index: 90; text-align: left; background: #1f2937; border-right: 2px solid #4b5563; }
    thead tr.group-row th.sec { border-left: 2px solid #4b5563; }

    thead tr.field-row th {
      background: #f3f4f6; color: #374151;
      font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px;
      padding: 0 12px; height: 34px; text-align: left; white-space: nowrap;
      border-bottom: 2px solid #d1d5db; border-right: 1px solid #e5e7eb;
      position: sticky; top: 34px; z-index: 50;
    }
    thead tr.field-row th.sf1 { position: sticky; left: 0;     top: 34px; z-index: 80; background: #f3f4f6; }
    thead tr.field-row th.sf2 {
      position: sticky; left: 315px; top: 34px; z-index: 80; background: #f3f4f6;
      box-shadow: 3px 0 6px -2px rgba(0,0,0,0.10); border-right: 2px solid #d1d5db;
    }
    thead tr.field-row th.ss { border-left: 2px solid #d1d5db; }

    tbody td {
      padding: 9px 12px; border-bottom: 1px solid #f3f4f6; border-right: 1px solid #f3f4f6;
      vertical-align: middle; color: #1f2937; background: #fff;
      white-space: nowrap;
    }
    tbody tr { cursor: pointer; }
    tbody tr:hover td { background: #f0f4ff; }
    tbody tr:hover td.sb1,
    tbody tr:hover td.sb2 { background: #e8eeff; }

    tbody td.lic-cell { white-space: normal; width: 125px; min-width: 125px; max-width: 125px; }
    thead tr.field-row th.lic-th { min-width: 125px; width: 125px; }

    tbody td.sb1 {
      position: sticky; left: 0; z-index: 10;
      background: #fff; font-weight: 600; border-right: none;
      width: 315px; min-width: 315px; max-width: 315px;
      overflow: hidden; text-overflow: ellipsis;
    }
    tbody td.sb2 {
      position: sticky; left: 315px; z-index: 10;
      background: #fff; box-shadow: 3px 0 6px -2px rgba(0,0,0,0.10);
      border-right: 2px solid #e5e7eb;
      width: 100px; min-width: 100px; max-width: 100px;
    }
    tbody td.ss { border-left: 2px solid #e5e7eb; }

    .desig-badge {
      display: inline-flex; align-items: center; padding: 2px 8px;
      border-radius: 10px; font-size: 10px; font-weight: 600; white-space: nowrap;
    }
    .desig-tech      { background: #e0f2fe; color: #0369a1; }
    .desig-tech-a    { background: #dcfce7; color: #15803d; }
    .desig-lead-tech { background: #d1fae5; color: #065f46; }
    .desig-ms        { background: #fef3c7; color: #92400e; }
    .desig-lae-b1    { background: #ede9fe; color: #5b21b6; }
    .desig-lae-b2    { background: #fce7f3; color: #9d174d; }
    .desig-le        { background: #dbeafe; color: #1d4ed8; }
    .desig-le-ops    { background: #e0e7ff; color: #3730a3; }
    .desig-mgr       { background: #f1f5f9; color: #334155; }
    .desig-other     { background: #f3f4f6; color: #6b7280; }

    .exp-badge {
      display: inline-flex; align-items: center; padding: 2px 6px;
      border-radius: 8px; font-size: 10px; font-weight: 600; white-space: nowrap;
    }
    .exp-badge.expired  { background: #fee2e2; color: #dc2626; }
    .exp-badge.critical { background: #ffedd5; color: #ea580c; }
    .exp-badge.warning  { background: #fef9c3; color: #ca8a04; }
    .exp-badge.ok       { background: #dcfce7; color: #16a34a; }

    .doc-link {
      display: inline-flex; align-items: center;
      color: #374151; text-decoration: none; padding: 2px;
      transition: opacity 0.15s;
    }
    .doc-link:hover { opacity: 0.55; }
    .doc-link svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 1.5; }

    .vm-btn {
      background: none; border: none; padding: 0; margin: 0; cursor: pointer;
      font-size: 11px; font-weight: 400; color: #374151;
      font-family: inherit; text-decoration: underline; text-decoration-color: transparent;
      transition: font-weight 0.05s, text-decoration-color 0.15s;
    }
    .vm-btn:hover { font-weight: 700; text-decoration-color: #374151; }

    .chips { display: flex; flex-wrap: wrap; gap: 3px; }
    .chip {
      display: inline-flex; padding: 1px 6px; border-radius: 8px;
      font-size: 10px; font-weight: 500;
      background: #f3f4f6; color: #374151; border: 1px solid #e5e7eb; white-space: nowrap;
    }
    .chip.hl { background: #374151; color: #fff; border-color: #374151; }

    .no-data { padding: 60px 24px; text-align: center; color: #9ca3af; font-size: 14px; }

    .error-screen { display: none; align-items: center; justify-content: center; height: 100vh; flex-direction: column; gap: 12px; background: #fff; }
    .error-screen.show { display: flex; }
    .error-screen h2 { color: #1f2937; font-size: 18px; }
    .error-screen p  { color: #6b7280; font-size: 13px; }

    /* ── Base Modal ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.45); z-index: 1000;
      justify-content: center; align-items: center; padding: 20px;
    }
    .modal-overlay.show { display: flex; }
    .modal-box {
      background: #fff; border-radius: 12px;
      width: 100%; max-width: 520px; max-height: 82vh;
      overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.18);
      display: flex; flex-direction: column;
    }
    .modal-header {
      padding: 16px 20px 12px; border-bottom: 1px solid #e5e7eb;
      display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
      flex-shrink: 0;
    }
    .modal-title { font-size: 14px; font-weight: 700; color: #1f2937; line-height: 1.4; }
    .modal-close {
      background: none; border: none; font-size: 22px; color: #6b7280;
      cursor: pointer; padding: 0 4px; line-height: 1; border-radius: 4px; flex-shrink: 0;
    }
    .modal-close:hover { background: #f3f4f6; color: #1f2937; }
    .modal-body { padding: 16px 20px; overflow-y: auto; flex: 1; }
    .modal-section { margin-bottom: 18px; }
    .modal-section:last-child { margin-bottom: 0; }
    .modal-sec-title {
      font-size: 10px; font-weight: 700; color: #fff;
      background: #374151; padding: 3px 10px; border-radius: 4px;
      margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block;
    }
    .modal-item { padding: 7px 10px; border-bottom: 1px solid #f3f4f6; font-size: 13px; color: #1f2937; }
    .modal-item:last-child { border-bottom: none; }
    .modal-row { display: flex; align-items: flex-start; padding: 7px 0; border-bottom: 1px solid #f3f4f6; font-size: 13px; }
    .modal-row:last-child { border-bottom: none; }
    .modal-rl { width: 130px; flex-shrink: 0; color: #6b7280; font-weight: 500; font-size: 12px; padding-top: 1px; }
    .modal-rv { color: #1f2937; flex: 1; word-break: break-word; white-space: normal; }
    .modal-nil { color: #9ca3af; font-style: italic; font-size: 13px; padding: 12px 0; }

    /* ── Change Modal specific ── */
    .cm-field-card {
      border: 1.5px solid #e5e7eb; border-radius: 8px;
      margin-bottom: 10px; overflow: hidden; transition: border-color 0.15s;
    }
    .cm-field-card.active { border-color: #6366f1; }
    .cm-field-card.status-card { border-color: #fca5a5; }
    .cm-field-card.status-card.active { border-color: #dc2626; }
    .cm-field-label {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px; background: #f9fafb; cursor: pointer;
      user-select: none;
    }
    .cm-field-card.status-card .cm-field-label { background: #fff5f5; }
    .cm-field-label input[type=checkbox] { width: 15px; height: 15px; cursor: pointer; accent-color: #4f46e5; flex-shrink: 0; }
    .cm-field-card.status-card .cm-field-label input[type=checkbox] { accent-color: #dc2626; }
    .cm-field-name { font-size: 12px; font-weight: 600; color: #374151; }
    .cm-field-card.status-card .cm-field-name { color: #dc2626; }
    .cm-current-tag {
      margin-left: auto; font-size: 11px; color: #9ca3af;
      background: #f3f4f6; padding: 2px 8px; border-radius: 6px;
      white-space: nowrap;
    }
    .cm-panel {
      display: none; padding: 12px 14px;
      border-top: 1.5px solid #e5e7eb; background: #fff;
    }
    .cm-field-card.status-card .cm-panel { border-top-color: #fecaca; }
    .cm-panel.open { display: block; }
    .cm-arrow-row {
      display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    }
    .cm-from-tag {
      font-size: 11px; font-weight: 600; color: #6b7280;
      background: #f3f4f6; padding: 3px 10px; border-radius: 6px;
      white-space: nowrap; flex-shrink: 0;
    }
    .cm-arrow { color: #d1d5db; font-size: 14px; font-weight: 700; flex-shrink: 0; }
    .cm-field-card.no-change { border-color: #f59e0b; }
    .cm-field-card.no-change .cm-panel { border-top-color: #fde68a; background: #fffbeb; }
    .cm-no-change-hint {
      font-size: 10px; color: #b45309; font-weight: 600;
      margin-top: 6px; display: none;
    }
    .cm-no-change-hint.show { display: block; }
    .cm-date-input {
      padding: 5px 8px; border: 1.5px solid #e5e7eb; border-radius: 6px;
      font-size: 12px; color: #374151; font-family: inherit;
      transition: border-color 0.15s;
    }
    .cm-date-input:focus { outline: none; border-color: #6b7280; }
    .cm-submit-btn {
      padding: 8px 22px; background: #1f2937; color: #fff;
      border: none; border-radius: 6px; font-size: 12px; font-weight: 600;
      cursor: pointer; font-family: inherit; transition: background 0.15s;
    }
    .cm-submit-btn:hover { background: #374151; }
    .cm-submit-btn:disabled { background: #9ca3af; cursor: not-allowed; }

    /* ── Nav ── */
    .nav-tabs { display: flex; gap: 4px; }
    .nav-tab {
      padding: 6px 14px; border-radius: 6px; font-size: 12px; font-weight: 600;
      cursor: pointer; border: 1.5px solid #e5e7eb; background: #fff; color: #6b7280;
      font-family: inherit; transition: all 0.15s; white-space: nowrap;
    }
    .nav-tab.tab-dashboard.active { background: #1f2937; color: #fff; border-color: #1f2937; }
    .nav-tab.tab-dashboard:not(.active):hover { background: #f3f4f6; color: #374151; }
    .nav-tab.tab-landing { border-color: #d1d5db; color: #6b7280; }
    .nav-tab.tab-landing:hover { background: #f3f4f6; color: #374151; border-color: #9ca3af; }
    .nav-tab.tab-absence { border-color: #dc2626; color: #dc2626; }
    .nav-tab.tab-absence.active { background: #dc2626; color: #fff; border-color: #dc2626; }
    .nav-tab.tab-absence:not(.active):hover { background: #fee2e2; }
    .nav-tab.tab-disc { border-color: #6b7280; color: #4b5563; }
    .nav-tab.tab-disc.active { background: #4b5563; color: #fff; border-color: #4b5563; }
    .nav-tab.tab-disc:not(.active):hover { background: #f3f4f6; color: #1f2937; }

    .abs-badge {
      display: inline-flex; align-items: center; padding: 2px 8px;
      border-radius: 10px; font-size: 10px; font-weight: 600; white-space: nowrap;
    }
    .abs-medical     { background: #dbeafe; color: #1d4ed8; }
    .abs-hosp        { background: #fee2e2; color: #dc2626; }
    .abs-emergency   { background: #fef3c7; color: #92400e; }
    .abs-quarantine  { background: #ede9fe; color: #5b21b6; }
    .abs-other       { background: #f3f4f6; color: #6b7280; }

    .disc-badge {
      display: inline-flex; align-items: center; padding: 2px 8px;
      border-radius: 10px; font-size: 10px; font-weight: 600; white-space: nowrap;
    }
    .disc-warning    { background: #fee2e2; color: #b91c1c; }
    .disc-reprimand  { background: #fef9c3; color: #854d0e; }
    .disc-show-cause { background: #ffedd5; color: #9a3412; }
    .disc-suspension { background: #fce7f3; color: #9d174d; }
    .disc-dismissal  { background: #4c1d95; color: #fff; }
    .disc-other      { background: #f3f4f6; color: #6b7280; }

    @media (max-width: 768px) {
      .topbar { padding: 10px 14px; gap: 10px; }
      .topbar-title { font-size: 14px; }
      .stats-row { padding: 6px 14px; gap: 14px; }
      .stat-value { font-size: 15px; }
      .filter-bar { padding: 6px 14px; gap: 6px; }
      .search-input { min-width: 140px; }
      thead tr.group-row th, thead tr.group-row th.sg1, thead tr.group-row th.sg2,
      thead tr.field-row th, thead tr.field-row th.sf1, thead tr.field-row th.sf2,
      thead tr.abs-head th, thead tr.abs-head th.sa1,
      tbody td.sb1, tbody td.sb2, tbody td.abs-sb1 {
        position: static !important; z-index: auto !important; box-shadow: none !important;
      }
      tbody td.sb1 { width: auto !important; min-width: 160px !important; max-width: none !important; }
      tbody td.sb2 { width: auto !important; min-width: 80px !important; max-width: none !important; }
      tbody td.abs-sb1 { width: auto !important; min-width: 160px !important; max-width: none !important; }
      /* Disciplinary — fully scrollable on mobile, no sticky columns */
      #discTable thead th,
      #discTable tbody td { position: static !important; z-index: auto !important; box-shadow: none !important; }
      .cm-arrow-row { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

<div class="loading-screen" id="loadingScreen">
  <div class="spinner"></div>
  <p>Loading dashboard...</p>
</div>

<div class="error-screen" id="errorScreen">
  <h2>Access Denied</h2>
  <p id="errorMsg">You do not have permission to view this dashboard.</p>
</div>

<!-- ── View-More / Info Modal ── -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal()">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div class="modal-title" id="modalTitle"></div>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="modal-body" id="modalBody"></div>
  </div>
</div>

<!-- ── Staff Change Modal ── -->
<div class="modal-overlay" id="changeModalOverlay" onclick="closeChangeModal()">
  <div class="modal-box" style="max-width:580px" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div>
        <div class="modal-title" id="cmTitle">Update Staff Record</div>
        <div style="font-size:11px;color:#9ca3af;margin-top:3px" id="cmSubtitle"></div>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <button id="cmAdminBtn" onclick="openAdminModal()" style="padding:5px 12px;background:#374151;color:#fff;border:none;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;display:none">⚙ Admin</button>
        <button class="modal-close" onclick="closeChangeModal()">×</button>
      </div>
    </div>
    <div class="modal-body" id="cmBody"></div>
  </div>
</div>

<!-- ── Admin / MAB Modal ── -->
<div class="modal-overlay" id="adminModalOverlay" onclick="closeAdminModal()" style="z-index:1100">
  <div class="modal-box" style="max-width:420px" onclick="event.stopPropagation()">
    <div class="modal-header">
      <div>
        <div class="modal-title">Admin Actions</div>
        <div style="font-size:11px;color:#9ca3af;margin-top:3px" id="adminModalSubtitle"></div>
      </div>
      <button class="modal-close" onclick="closeAdminModal()">×</button>
    </div>
    <div class="modal-body">
      <div style="margin-bottom:10px;font-size:12px;color:#6b7280;font-weight:500">MAB Pass Documents</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        <button onclick="generateMabDoc('new')" id="mabNewBtn"
          style="padding:10px 16px;background:#fff;color:#1d4ed8;border:1.5px solid #1d4ed8;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;text-align:left;transition:all 0.15s"
          onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='#fff'">
          Generate MAB New Application
        </button>
        <button onclick="generateMabDoc('renewal')" id="mabRenewalBtn"
          style="padding:10px 16px;background:#fff;color:#0f766e;border:1.5px solid #0f766e;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;text-align:left;transition:all 0.15s"
          onmouseover="this.style.background='#f0fdfa'" onmouseout="this.style.background='#fff'">
          Generate MAB Renewal Application
        </button>
      </div>
      <div id="mabStatus" style="margin-top:14px;font-size:12px;display:none"></div>
    </div>
  </div>
</div>

<!-- ════ DASHBOARD PAGE ════ -->
<div class="page" id="page">
  <div class="topbar">
    <div>
      <div class="topbar-title">Staff Dashboard</div>
      <div class="topbar-subtitle">ADE KUL Line Maintenance — Part 145</div>
    </div>
    <div class="nav-tabs">
      <button class="nav-tab tab-landing" onclick="goToLanding()">← Landing</button>
      <button class="nav-tab tab-dashboard active" onclick="showPage('dashboard')">Dashboard</button>
      <button class="nav-tab tab-absence" onclick="showPage('absence')">Absence</button>
      <button class="nav-tab tab-disc" onclick="showPage('disc')">Disciplinary</button>
    </div>
    <div style="font-size:11px;color:#9ca3af" id="lastRefresh"></div>
  </div>

  <div class="stats-row">
    <div class="stat-item">
      <div class="stat-value" id="statTotal">—</div>
      <div class="stat-label">Total Staff</div>
    </div>
    <div class="stat-divider"></div>
