      .map(function(x) { return x.trim(); })
      .filter(Boolean)
      .sort(function(a, b) { return parseInt(a) - parseInt(b); });

    var html = '';
    if (items.length) {
      html += '<div class="modal-section">' +
        '<div class="modal-sec-title">Limitation Numbers</div>';
      items.forEach(function(num) {
