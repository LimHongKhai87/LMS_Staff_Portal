  // ── Helpers ───────────────────────────────────────────────────────────────────
  function expiryStatus(dateVal) {
    if (!dateVal || !String(dateVal).trim()) return null;
    var d = new Date(dateVal); d.setHours(0,0,0,0);
    if (isNaN(d.getTime())) return null;
    var diff = Math.ceil((d - today) / 86400000);
    if (diff < 0)    return 'expired';
    if (diff <= 90)  return 'critical';
    if (diff <= 180) return 'warning';
    return 'ok';
  }
  function expiryBadge(dateVal) {
    if (!dateVal || !String(dateVal).trim()) return dash();
    var s = expiryStatus(dateVal);
    if (!s) return String(dateVal);
    var labels = { expired:'Expired', critical:'< 90 days', warning:'< 180 days', ok:'Valid' };
    return '<span style="display:block;font-size:11px;margin-bottom:2px">' + dateVal + '</span>' +
           '<span class="exp-badge ' + s + '">' + labels[s] + '</span>';
  }
  function docLink(url) {
    if (!url) return '';
    return '<a href="' + url + '" target="_blank" class="doc-link" onclick="event.stopPropagation()">' + docSvg + '</a>';
  }
  function extractUrl(raw) {
    if (!raw) return '';
    var s = String(raw).trim();
    if (s.indexOf('http') === 0) return s;
    var m = s.match(/HYPERLINK\s*\(\s*"([^"]+)"/i); if (m) return m[1];
    var m2 = s.match(/https?:\/\/[^\s"'<>]+/); return m2 ? m2[0] : '';
  }
  function chips(csvStr, hl) {
    if (!csvStr || !String(csvStr).trim()) return dash();
    var parts = String(csvStr).split(',').map(function(x){ return x.trim(); }).filter(Boolean);
    if (!parts.length) return dash();
    return '<div class="chips">' + parts.map(function(p) {
      return '<span class="chip' + (hl ? ' hl' : '') + '">' + p + '</span>';
    }).join('') + '</div>';
  }
  function dash() { return '<span style="color:#d1d5db;font-style:italic;font-size:11px">—</span>'; }
  function v(x)   { return x && String(x).trim() ? String(x).trim() : null; }
  function fmtDate(dv) {
    if (!dv) return null;
    try {
      var d = new Date(dv);
      if (isNaN(d.getTime())) return dv;
      return d.toLocaleDateString('en-MY', { year:'numeric', month:'short', day:'numeric' });
    } catch(e) { return dv; }
  }
  function hasContent(s) { return !!(s && String(s).trim() && String(s).trim() !== 'Not Avail'); }
  function desigBadge(val) {
    if (!val || !val.trim()) return dash();
    var cls = DESIG_CLASS[val.trim()] || 'desig-other';
    return '<span class="desig-badge ' + cls + '">' + val.trim() + '</span>';
  }
  function licenseChips(csvStr) {
    if (!csvStr || !String(csvStr).trim()) return '<span style="color:#e5e7eb;font-style:italic;font-size:11px">None</span>';
    var upper = String(csvStr).trim().toUpperCase();
    if (upper === 'NONE' || upper === 'NIL' || upper === 'N/A') {
      return '<span style="color:#d1d5db;font-size:10px;font-weight:500">None</span>';
    }
    return chips(csvStr, true);
  }
  function vmBtn(fn) {
    return '<button class="vm-btn" onclick="event.stopPropagation();' + fn + '">View More</button>';
  }

  // ── Render ────────────────────────────────────────────────────────────────────
  function renderTable(rows) {
    var tbody  = document.getElementById('tableBody');
    var noData = document.getElementById('noData');
    tbody.innerHTML = '';

    if (!rows.length) {
      noData.style.display = 'block';
      return;
    }
    noData.style.display = 'none';

    var CHUNK = 40;
    var index = 0;

    // Show a lightweight progress bar while chunks render
    var prog = document.createElement('tr');
    prog.id  = 'renderProgress';
    prog.innerHTML =
      '<td colspan="99" style="padding:10px 24px;color:#9ca3af;font-size:12px;text-align:center">' +
      'Rendering <span id="renderCount">0</span> of ' + rows.length + ' rows…</td>';
    tbody.appendChild(prog);

    function renderChunk() {
      var progRow = document.getElementById('renderProgress');

      // Build HTML for this chunk
      var html = '';
      var end  = Math.min(index + CHUNK, rows.length);
      for (var i = index; i < end; i++) html += buildRow(rows[i], i);
      index = end;

      // Parse into a temporary element and move nodes into real tbody
      var temp = document.createElement('table');
      temp.innerHTML = '<tbody>' + html + '</tbody>';
      var tempBody = temp.querySelector('tbody');
      while (tempBody.firstChild) tbody.insertBefore(tempBody.firstChild, progRow);

      // Update or remove progress indicator
      if (index < rows.length) {
        var ct = document.getElementById('renderCount');
        if (ct) ct.textContent = index;
        requestAnimationFrame(renderChunk);
      } else {
        if (progRow) progRow.parentNode.removeChild(progRow);
      }
    }

    requestAnimationFrame(renderChunk);
  }

