    status.style.display = 'block';
    status.innerHTML = '<div style="color:#6b7280">⏳ Generating document, please wait…</div>';

    var todayStr = new Date().toLocaleDateString('en-GB', { year:'numeric', month:'short', day:'2-digit' });

    var payload = {
      type:    type,
      name:    v(r.full_name)     || '',
      staffNo: v(r.staff_no)      || '',
      ic:      v(r.ic_no)         || '',
      date:    todayStr
    };

    google.script.run
      .withSuccessHandler(function(result) {
        if (result && result.success) {
          var pdfIcon = '<svg style="width:15px;height:15px;vertical-align:middle;margin-right:4px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>';
          status.innerHTML =
            '<div style="color:#166534;margin-bottom:8px">Document generated successfully!</div>' +
            '<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:6px;padding:10px 14px">' +
              '<a href="' + result.pdfUrl + '" target="_blank" style="display:inline-flex;align-items:center;color:#374151;font-weight:400;text-decoration:none;font-size:13px">' +
                pdfIcon + 'Open PDF in Drive' +
              '</a>' +
            '</div>';
        } else {
          status.innerHTML = '<span style="color:#dc2626">❌ Error: ' + (result ? result.message : 'Unknown error') + '</span>';
          [newBtn, renewalBtn].forEach(function(btn) {
            if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
          });
        }
      })
      .withFailureHandler(function(err) {
        status.innerHTML = '<span style="color:#dc2626">❌ Failed: ' + (err.message || String(err)) + '</span>';
        [newBtn, renewalBtn].forEach(function(btn) {
          if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
        });
      })
      .generateMabDocument(payload);
  }
</script>
</body>
</html>
