<script>
  var allRows = [];
  var filteredRows = [];
  var today = new Date(); today.setHours(0,0,0,0);
  var docSvg = '<svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';

  var DESIG_ORDER = [
    'Technician', 'Technician - Cat A', 'Lead Technician',
    'Maintenance Supervisor', 'LAE - B1', 'LAE - B2',
    'Lead Engineer', 'Lead Engineer Ops', 'Manager'
  ];
  var DESIG_CLASS = {
    'Technician':            'desig-tech',
    'Technician - Cat A':    'desig-tech-a',
    'Lead Technician':       'desig-lead-tech',
    'Maintenance Supervisor':'desig-ms',
    'LAE - B1':              'desig-lae-b1',
    'LAE - B2':              'desig-lae-b2',
    'Lead Engineer':         'desig-le',
    'Lead Engineer Ops':     'desig-le-ops',
    'Manager':               'desig-mgr'
  };
  var SHIFT_LIST = ['A','C','B','D','Float-A','Float-B','Cart-A','Cart-B','A/O','LMCC'];

  function goToLanding() {
    google.script.run
      .withSuccessHandler(function(url) { window.top.location.href = url; })
      .withFailureHandler(function()    { window.top.location.href = window.top.location.href.split('?')[0]; })
      .getScriptUrl();
  }

  // ── Boot ─────────────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    var timeout = setTimeout(function() { showError('Server timeout. Please refresh.'); }, 20000);
    google.script.run
      .withSuccessHandler(function(result) {
        clearTimeout(timeout);
        if (!result || !result.rows) { showError('No data returned.'); return; }
        allRows = result.rows.sort(function(a, b) {
          var na = (a.full_name || '').toLowerCase();
          var nb = (b.full_name || '').toLowerCase();
          return na < nb ? -1 : na > nb ? 1 : 0;
        });
        buildFilters();
        applyFilters();
        updateStats();
        document.getElementById('loadingScreen').style.display = 'none';
        document.getElementById('page').classList.add('show');
        document.getElementById('lastRefresh').textContent =
          'Refreshed: ' + new Date().toLocaleTimeString('en-MY');
      })
      .withFailureHandler(function(err) {
        clearTimeout(timeout);
        showError(err.message || String(err));
      })
      .getDashboardData();
  });

  function showError(msg) {
    document.getElementById('loadingScreen').style.display = 'none';
    document.getElementById('errorMsg').textContent = msg;
    document.getElementById('errorScreen').classList.add('show');
  }

  // ── Filters ──────────────────────────────────────────────────────────────────
  function buildFilters() {
    var existingDesigs = unique('designation');
    var orderedDesigs = DESIG_ORDER.filter(function(d) { return existingDesigs.indexOf(d) !== -1; });
    existingDesigs.forEach(function(d) { if (orderedDesigs.indexOf(d) === -1) orderedDesigs.push(d); });
    populateFilter('filterDesignation', orderedDesigs);
    populateFilter('filterTeam',  unique('team'));
    populateFilter('filterShift', unique('shift'));
  }
  function unique(field) {
    var seen = {}, out = [];
    allRows.forEach(function(r) {
      var val = (r[field] || '').trim();
      if (val && !seen[val]) { seen[val] = 1; out.push(val); }
    });
    return out.sort();
  }
  function populateFilter(id, values) {
    var sel = document.getElementById(id);
    var first = sel.options[0];
    sel.innerHTML = ''; sel.appendChild(first);
    values.forEach(function(val) {
      var opt = document.createElement('option');
      opt.value = val; opt.textContent = val; sel.appendChild(opt);
    });
  }
  function applyFilters() {
    var fDesig   = document.getElementById('filterDesignation').value;
    var fTeam    = document.getElementById('filterTeam').value;
    var fShift   = document.getElementById('filterShift').value;
    var fLicense = document.getElementById('filterLicense').value;
    var fSearch  = document.getElementById('searchInput').value.toLowerCase().trim();

    filteredRows = allRows.filter(function(r) {
      if (fDesig   && (r.designation || '').trim() !== fDesig)  return false;
      if (fTeam    && (r.team        || '').trim() !== fTeam)   return false;
      if (fShift   && (r.shift       || '').trim() !== fShift)  return false;
      if (fLicense) {
        var lic = (r.available_license || '').toUpperCase();
        if (fLicense === 'AMEL' && lic.indexOf('AMEL') === -1) return false;
        if (fLicense === 'AMTL' && lic.indexOf('AMTL') === -1) return false;
        if (fLicense === 'None' && lic !== '' && lic !== 'NONE') return false;
      }
      if (fSearch) {
        var hay = ((r.full_name || '') + ' ' + (r.staff_no || '')).toLowerCase();
        if (hay.indexOf(fSearch) === -1) return false;
      }
      return true;
    });

    renderTable(filteredRows);
    document.getElementById('resultCount').textContent = filteredRows.length + ' of ' + allRows.length + ' staff';
    document.getElementById('statFiltered').textContent = filteredRows.length;
  }
  function clearFilters() {
    ['filterDesignation','filterTeam','filterShift','filterLicense'].forEach(function(id) {
      document.getElementById(id).value = '';
    });
    document.getElementById('searchInput').value = '';
    applyFilters();
  }

  function updateStats() {
    document.getElementById('statTotal').textContent = allRows.length;
    var licensed = 0;
    allRows.forEach(function(r) {
      var lic = (r.available_license || '').toUpperCase();
      if (lic.indexOf('AMEL') !== -1 || lic.indexOf('AMTL') !== -1) licensed++;
    });
