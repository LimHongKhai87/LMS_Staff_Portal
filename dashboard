  function submitChangeModal() {
    var r = changeModalRow;
    if (!r) return;

    var changes      = [];
    var statusChange = null;

    // ── Collect Designation ────────────────────────────────────────────
    var cbDesig = document.getElementById('cmCb_desig');
    if (cbDesig && cbDesig.checked) {
      var toDesig = document.getElementById('cmDesigTo').value;
      var dtDesig = document.getElementById('cmDate_desig').value;
      if (!dtDesig) { alert('Please select an effective date for Designation change.'); return; }
      changes.push({ type: 'Designation', toVal: toDesig, date: dtDesig });
    }

    // ── Collect Section ────────────────────────────────────────────────
    var cbSection = document.getElementById('cmCb_section');
    if (cbSection && cbSection.checked) {
      var toSection = document.getElementById('cmSectionTo').value;
      var dtSection = document.getElementById('cmDate_section').value;
      if (!dtSection) { alert('Please select an effective date for Section change.'); return; }
      changes.push({ type: 'Section', toVal: toSection, date: dtSection });
    }

    // ── Collect Shift ──────────────────────────────────────────────────
    var cbShift = document.getElementById('cmCb_shift');
    if (cbShift && cbShift.checked) {
      var toShift = document.getElementById('cmShiftTo').value;
      var dtShift = document.getElementById('cmDate_shift').value;
      if (!dtShift) { alert('Please select an effective date for Shift change.'); return; }
      changes.push({ type: 'Shift', toVal: toShift, date: dtShift });
    }

    // ── Collect Status ─────────────────────────────────────────────────
    var cbStatus = document.getElementById('cmCb_status');
    if (cbStatus && cbStatus.checked) {
      var statusReason = document.getElementById('cmStatusReason').value;
      var dtStatus     = document.getElementById('cmDate_status').value;
      if (!dtStatus) { alert('Please select an effective date for Status change.'); return; }
      statusChange = { reason: statusReason, date: dtStatus };
    }

    if (!changes.length && !statusChange) {
      alert('Please toggle at least one field to update.');
      return;
    }

    var btn = document.getElementById('cmSubmitBtn');
    btn.disabled = true;
    btn.textContent = 'Saving…';

    var payload = {
      staffNo:      v(r.staff_no)      || '',
      email:        v(r.email_address) || '',
      fullName:     v(r.full_name)     || '',
      curDesig:     v(r.designation)   || '',
      curSection:   v(r.team)          || '',
      curShift:     v(r.shift)         || '',
      changes:      changes,
      statusChange: statusChange
    };

    google.script.run
      .withSuccessHandler(function(result) {
        if (result && result.success) {
          closeChangeModal();
          // Refresh data to reflect updates
          google.script.run
            .withSuccessHandler(function(res) {
              if (res && res.rows) {
                allRows = res.rows.sort(function(a,b){
                  return (a.full_name||'').toLowerCase() < (b.full_name||'').toLowerCase() ? -1 : 1;
                });
                applyFilters();
                updateStats();
              }
            })
            .getDashboardData();
          alert('Changes saved successfully for ' + (v(r.full_name) || 'staff') + '.');
        } else {
          alert('Error: ' + (result ? result.message : 'Unknown error'));
          btn.disabled = false;
          btn.textContent = 'Submit Changes';
        }
      })
      .withFailureHandler(function(err) {
        alert('Failed: ' + (err.message || String(err)));
        btn.disabled = false;
        btn.textContent = 'Submit Changes';
      })
      .submitStaffChange(payload);
  }

