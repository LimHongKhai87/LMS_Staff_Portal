        validateSubmitBtn(r);
      });
      // Re-validate on select change
      var sel = document.getElementById('cm' + key.charAt(0).toUpperCase() + key.slice(1) + 'To');
      if (sel) sel.addEventListener('change', function() { validateSubmitBtn(r); });
    });
    // Status reason select also triggers re-validate
    var statusSel = document.getElementById('cmStatusReason');
    if (statusSel) statusSel.addEventListener('change', function() { validateSubmitBtn(r); });

    // Initial state — button disabled until a real change is made
    validateSubmitBtn(r);
  }

  function validateSubmitBtn(r) {
    var btn = document.getElementById('cmSubmitBtn');
    if (!btn) return;

    var anyChecked  = false;
    var allValid    = true;

    // ── Designation ────────────────────────────────────────────────────
    var cbDesig = document.getElementById('cmCb_desig');
    if (cbDesig && cbDesig.checked) {
      anyChecked = true;
      var selDesig = document.getElementById('cmDesigTo');
      if (selDesig && selDesig.value === (v(r.designation) || '')) allValid = false;
    }

    // ── Section ────────────────────────────────────────────────────────
    var cbSection = document.getElementById('cmCb_section');
    if (cbSection && cbSection.checked) {
      anyChecked = true;
      var selSection = document.getElementById('cmSectionTo');
      if (selSection && selSection.value === (v(r.team) || '')) allValid = false;
    }

    // ── Shift ──────────────────────────────────────────────────────────
    var cbShift = document.getElementById('cmCb_shift');
    if (cbShift && cbShift.checked) {
      anyChecked = true;
      var selShift = document.getElementById('cmShiftTo');
      if (selShift && selShift.value === (v(r.shift) || '')) allValid = false;
    }

    // ── Status (always valid when checked — reason is always different) ─
    var cbStatus = document.getElementById('cmCb_status');
    if (cbStatus && cbStatus.checked) anyChecked = true;

    var enabled = anyChecked && allValid;
